# ===========================
# VocabAI 環境變數設定
# 複製此檔案為 .env 並填入實際值
# ===========================

# Database（Docker 預設值，本地開發時與 docker-compose.dev.yml 對應）
DATABASE_URL=postgresql://vocabai:vocabai_pass@localhost:5432/vocabai

# JWT 密鑰（請改成至少 32 字元的隨機字串）
SECRET_KEY=your-super-secret-key-change-this-in-production

# Gemini API Key（用於 AI 單字卡和測驗生成）
GEMINI_API_KEY=

# LINE Bot（Phase 3，目前可留空）
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# Frontend API URL
NEXT_PUBLIC_API_URL=http://localhost:8080
